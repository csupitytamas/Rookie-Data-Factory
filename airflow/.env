_PIP_ADDITIONAL_REQUIREMENTS=openpyxl pyyaml pyarrow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=False
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True
AIRFLOW__WEBSERVER__RBAC=True
AIRFLOW__WEBSERVER__WORKERS=4
AIRFLOW__WEBSERVER__WORKER_CLASS=gevent
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__LOGGING__REMOTE_LOGGING=False
AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=30
AIRFLOW__SCHEDULER__SCHEDULER_HEARTBEAT_SEC=10
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30
AIRFLOW__SCHEDULER__MAX_THREADS=4
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_SIZE=10
AIRFLOW__DATABASE__SQL_ALCHEMY_MAX_OVERFLOW=20
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_PRE_PING=True
AIRFLOW__DATABASE__LOAD_DEFAULT_CONNECTIONS=False
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__PARALLELISM=4
AIRFLOW__CELERY__WORKER_CONCURRENCY=4
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=2
DB_URL=postgresql+psycopg2://postgres:admin123@host.docker.internal:5433/ETL
AIRFLOW_CONN_WORLD_BANK_API='{"conn_type": "http", "host": "https://api.worldbank.org/v2"}'
AIRFLOW_CONN_WHO_API='{"conn_type": "http", "host": "https://ghoapi.azureedge.net/api"}'
AIRFLOW_CONN_OECD_API='{"conn_type": "http", "host": "https://sdmx.oecd.org/public/rest"}'
AIRFLOW_CONN_UN_DATA_API='{"conn_type": "http", "host": "https://data.un.org/ws/rest/data"}'